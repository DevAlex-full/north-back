# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT
# IMPORTANTE: JWT_SECRET e JWT_REFRESH_SECRET devem ser valores DIFERENTES entre si.
# O access token é assinado com JWT_SECRET; o refresh token é assinado
# separadamente com JWT_REFRESH_SECRET (via biblioteca jsonwebtoken).
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-and-different-from-jwt-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS
CORS_ORIGIN="*"


SEED_USER_EMAIL="alex@north.app"
SEED_USER_PASSWORD="change-me"